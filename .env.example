# Copy to .env for local dev. On Hugging Face, set these as Space secrets instead.

# Base URL of the Modal-hosted vLLM OpenAI-compatible server (from `modal deploy`).
# Example: https://yourname--bonsai-minicpm-serve.modal.run/v1
MODAL_ENDPOINT_URL=

# Shared secret sent as a Bearer token to the Modal endpoint.
MODAL_API_KEY=

# Model id as served by vLLM (must match modal_app.py).
MODEL_ID=openbmb/MiniCPM-V-4_5

# Where the working SQLite db lives. /data is persistent on HF if persistent
# storage is enabled; otherwise it resets on rebuild (seed.db is re-copied).
BONSAI_DB_PATH=/data/bonsai.db

# Set to "1" to use the in-Space ZeroGPU fallback instead of Modal.
USE_ZEROGPU_FALLBACK=0
